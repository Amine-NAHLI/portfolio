{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "type-check": "tsc --noEmit --incremental false",
    "test": "node --test --experimental-strip-types \"tests/**/*.test.ts\"",
    "test:coverage": "node --test --experimental-strip-types --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=80 --test-coverage-branches=75 \"tests/**/*.test.ts\"",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:links": "node scripts/check-links.mjs",
    "test:e2e": "node scripts/run-e2e.mjs",
    "test:e2e:headed": "node scripts/run-e2e.mjs --headed",
    "test:lighthouse": "node scripts/lighthouse-audit.mjs",
    "test:db": "supabase test db --local supabase/tests/database",
    "test:db:lint": "supabase db lint --local --schema public,private --fail-on error",
    "check": "npm run type-check && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "mermaid": "11.16.0",
    "next": "15.5.20",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chrome-launcher": "1.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "lighthouse": "12.6.1",
    "postcss": "^8.5.13",
    "supabase": "2.109.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}

# Public site URL used for canonical URLs, Open Graph and sitemap generation.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Free project (public values; safe for browser use when RLS is enabled).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy key name accepted during migration only. Prefer the publishable key above.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never prefix with NEXT_PUBLIC and never expose to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Increases the official GitHub API rate limit for repository analysis.
# The portfolio works without it using GitHub's unauthenticated public limit.
GITHUB_TOKEN=

# Required to enable the contact form in production. Generate at least 32 random bytes.
CONTACT_FINGERPRINT_SECRET=

# Privacy-preserving, first-party aggregate analytics. Disabled by default.
NEXT_PUBLIC_ANALYTICS_ENABLED=false
